# ---- Server ----
PORT=5000

# ---- Google Sign-In (OAuth 2.0 Web client ID from Google Cloud Console) ----
# https://console.cloud.google.com/apis/credentials → Create OAuth client ID →
# Web application. Authorized JS origin: http://localhost:5173
# Must MATCH the frontend VITE_GOOGLE_CLIENT_ID. Leave blank to disable SSO.
GOOGLE_CLIENT_ID=

# ---- MongoDB ----
# Local: mongodb://127.0.0.1:27017/niveshmitra
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/niveshmitra
MONGODB_URI=mongodb://127.0.0.1:27017/niveshmitra

# ---- LLM provider: Google Gemini (native REST API) ----
LLM_PROVIDER=gemini

# ---- Google Gemini (free key: https://aistudio.google.com/apikey) ----
# Uses the NATIVE REST API (X-goog-api-key header) — works with both
# "AQ." AI-Studio keys and "AIza" keys.
GEMINI_API_KEY=
# Pick a model your project has quota for (gemini-2.5-flash is a solid free pick).
GEMINI_MODEL=gemini-2.5-flash
# Tried in order if the primary model is overloaded (503).
GEMINI_FALLBACK_MODELS=gemini-flash-lite-latest,gemini-3-flash-preview

# Set to "true" to force canned responses without calling the LLM (demo fallback).
# If GEMINI_API_KEY is empty, mock mode turns on automatically.
MOCK_LLM=false
